# WhatsApp Number (Required)
# Format: Country code + number (no spaces, no + sign)
# Example: 15551234567 for US +1 (555) 123-4567
# Example: 919876543210 for India +91 98765 43210
VITE_WHATSAPP_NUMBER=1234567890
